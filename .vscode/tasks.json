{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "linux-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake Build Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "linux-debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "dependsOn": "CMake Configure Debug"
    },
    {
      "label": "Git Pull With Submodules",
      "type": "shell",
      "command": "git",
      "args": [
        "pull",
        "--recurse-submodules"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "Git Submodule Update"
      ]
    },
    {
      "label": "Git Submodule Update",
      "type": "shell",
      "command": "git",
      "args": [
        "submodule",
        "update",
        "--init",
        "--recursive"
      ],
      "problemMatcher": []
    }
  ]
}